{
	"$schema": "https://json.schemastore.org/nest-cli",
	"collection": "@nestjs/schematics",
	"sourceRoot": "apps/api/src",
	"compilerOptions": {
		"deleteOutDir": true,
		"webpack": true,
		"tsConfigPath": "apps/api/tsconfig.app.json"
	},
	"monorepo": true,
	"root": "apps/api",
	"projects": {
		"ai": {
			"type": "library",
			"root": "libs/ai",
			"entryFile": "index",
			"sourceRoot": "libs/ai/src",
			"compilerOptions": {
				"tsConfigPath": "libs/ai/tsconfig.lib.json"
			}
		},
		"api": {
			"type": "application",
			"root": "apps/api",
			"entryFile": "main",
			"sourceRoot": "apps/api/src",
			"compilerOptions": {
				"tsConfigPath": "apps/api/tsconfig.app.json"
			}
		},
		"workers": {
			"type": "application",
			"root": "apps/workers",
			"entryFile": "main",
			"sourceRoot": "apps/workers/src",
			"compilerOptions": {
				"tsConfigPath": "apps/workers/tsconfig.app.json"
			}
		}
	}
}
