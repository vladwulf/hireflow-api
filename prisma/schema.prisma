// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Template {
  id   Int    @id @default(autoincrement())
  uuid String @unique @default(cuid())

  name     String
  template String // AI-generated template (null until first GET by uuid)
  category String
  tags     String[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  jobs Job[]

  @@map("templates")
}

model Job {
  id       String @id @default(cuid())
  title    String
  category String

  status JobStatus @default(ACTIVE)

  content String // generated job description text

  templateId Int
  template   Template @relation(fields: [templateId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  candidates Candidate[]

  @@map("jobs")
}

enum JobStatus {
  ACTIVE
  CLOSED
}

model Candidate {
  id        String   @id @default(cuid())
  name      String
  cvText    String // raw pasted CV text
  jobId     String
  job       Job      @relation(fields: [jobId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  score CandidateScore?

  @@map("candidates")
}

model CandidateScore {
  id          String    @id @default(cuid())
  overall     Int // 0–100
  skillsMatch Int // 0–100
  experience  Int // 0–100
  cultureFit  Int // 0–100
  summary     String
  pros        String[]
  cons        String[]
  candidateId String    @unique
  candidate   Candidate @relation(fields: [candidateId], references: [id])
  createdAt   DateTime  @default(now())

  @@map("candidate_scores")
}
